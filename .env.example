# Copy this file to .env and fill in the values.

# Host root (without shop region or locale segments)
E2E_BASE_URL=

# Shop region segment (e.g. shop-nl, shop-be)
E2E_SHOP=

# Language segment (e.g. nl, fr, en)
E2E_LOCALE=

# Platform HTTP basic-auth gate
E2E_PLATFORM_USER=
E2E_PLATFORM_PASSWORD=

# Application login user
E2E_USERNAME=
E2E_PASSWORD=
